# NetInsight-X environment variables
# Copy this file to .env and update the values for your deployment.

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,netinsight-x.onrender.com

# NetInsight
NETINSIGHT_DB_PATH=netinsight/database/netinsight.db
NETINSIGHT_SVM_PATH=netinsight/classification/svm_model.joblib
NETINSIGHT_DEMO_MODE=True
NETINSIGHT_LOG_LEVEL=INFO
